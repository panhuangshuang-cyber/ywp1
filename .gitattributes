# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.md text
*.json text
*.yml text
*.yaml text
*.toml text
*.xml text
*.html text
*.css text
*.js text
*.ts text
*.py text
*.sh text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary